{
  "mcpServers": {
    "postman-api": {
      "type": "sse",
      "url": "https://mcp.postman.com/mcp",
      "headers": {
        "Authorization": "Bearer ${input:postman-api-key}"
      }
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--allowed-hosts",
        "localhost,localhost:3000,localhost:3001,localhost:3100,localhost:3101,localhost:4000,localhost:4001"
      ]
    },
    "langchain-docs": {
      "type": "sse",
      "url": "https://docs.langchain.com/mcp"
    },
    "lsmcp": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@mizchi/lsmcp", "-p", "tsgo"]
    },
    "process-registry": {
      "type": "stdio",
      "command": "/Users/lg/go/bin/mcp-filesystem-server",
      "args": ["./thoughts"]
    }
  },
  "inputs": [
    {
      "id": "postman-api-key",
      "type": "promptString",
      "description": "Enter your Postman API key (get from https://go.postman.co/settings/me/api-keys)"
    }
  ]
}
