# =========================================
# DAICER - Environment Configuration
# =========================================
# Copy this file to .env.local and fill in your values
# .env.local is gitignored and safe for secrets

# =========================================
# APPLICATION
# =========================================
NODE_ENV=development

# =========================================
# BACKEND (applies when running from /backend)
# =========================================
# Server port
PORT=3001

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# =========================================
# FRONTEND (VITE_ prefix required)
# =========================================
# Backend API URL
VITE_API_URL=http://localhost:3001

# Use Firebase emulators for local dev
VITE_USE_EMULATORS=true

# =========================================
# FIREBASE
# =========================================
# Project ID (required for both emulator and production)
FIREBASE_PROJECT_ID=demo-project
VITE_FIREBASE_PROJECT_ID=demo-project

# Backend production credentials (leave empty for emulators)
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Frontend production config (leave empty for emulators)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase emulator hosts (auto-set by firebase emulators:start)
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# =========================================
# AI SERVICES
# =========================================
# OpenAI API key (for embeddings and GPT models)
OPENAI_API_KEY=

# Google Gemini API key (for image generation and LLM)
GEMINI_API_KEY=

# =========================================
# LANGSMITH (Optional - for LLM tracing)
# =========================================
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=daicer
