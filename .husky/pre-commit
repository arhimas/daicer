#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# Generate release notes from thoughts/ files
echo "📝 Generating release notes from thoughts/..."
tsx scripts/generate-release-notes.ts

# Stage the updated release notes if changed
if [ -f "RELEASE_NOTES.md" ]; then
  git add RELEASE_NOTES.md
  git add scripts/release-notes-state.json
fi

echo "✅ Release notes updated"

