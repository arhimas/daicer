# ==============================================
# SOTA Docker Environment Configuration
# Copy this to .env to run against Docker Infrastructure
# ==============================================

# Server
HOST=0.0.0.0
PORT=1337

# Secrets (Keep these secure in production!)
APP_KEYS=${APP_KEYS}
API_TOKEN_SALT=${API_TOKEN_SALT}
ADMIN_JWT_SECRET=${ADMIN_JWT_SECRET}
TRANSFER_TOKEN_SALT=${TRANSFER_TOKEN_SALT}
ENCRYPTION_KEY=${ENCRYPTION_KEY}
JWT_SECRET=${JWT_SECRET}
STRAPI_AUDIT_TOKEN=${STRAPI_AUDIT_TOKEN}

# ----------------------------------------------
# DATABASE: Postgres (pgvector)
# ----------------------------------------------
DATABASE_CLIENT=postgres
# Use 'localhost' if running Strapi locally against Docker DB port 5432
# Use 'db' if running Strapi INSIDE Docker container
DATABASE_HOST=localhost 
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_SSL=false

# ----------------------------------------------
# REDIS: BullMQ
# ----------------------------------------------
# Use 'localhost' if running Strapi locally
# Use 'redis' if running Strapi INSIDE Docker container
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Enable Queues explicitly
ENABLE_QUEUES=true

# ----------------------------------------------
# AI / Embeddings
# ----------------------------------------------
AUTO_EMBEDDING_ENABLED=true
GEMINI_API_KEY=${GEMINI_API_KEY}
OPENAI_API_KEY=${OPENAI_API_KEY}

# ----------------------------------------------
# GCS (Media)
# ----------------------------------------------
GCS_BUCKET_NAME=${GCS_BUCKET_NAME}
GCS_PUBLIC_FILES=true
GCS_UNIFORM=true
GCS_SERVICE_ACCOUNT=${GCS_SERVICE_ACCOUNT}
