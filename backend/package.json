  "devDependencies": {
    "@types/gradient-string": "^1.1.6",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.0.3",
    "@types/pngjs": "^6.0.5",
    "@types/prettyjson": "^0.0.33",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/seedrandom": "^3.0.8",
    "@vitest/coverage-v8": "^4.0.16",
    "better-sqlite3": "^12.5.0",
    "jsonwebtoken": "^9.0.3",
    "ts-node": "^10.9.2",
