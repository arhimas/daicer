    "@langchain/openai": "^1.2.1",
    "@langchain/textsplitters": "^1.0.1",
    "@radix-ui/react-use-effect-event": "^0.0.2",
    "@strapi-community/strapi-provider-upload-google-cloud-storage": "^5.0.5",
    "@strapi/client": "^1.6.0",
    "@strapi/plugin-cloud": "5.32.0",
    "@strapi/plugin-graphql": "5.32.0",
    "@strapi/plugin-users-permissions": "5.32.0",
    "@strapi/strapi": "5.32.0",
    "@types/cli-progress": "^3.11.6",
    "axios": "^1.13.2",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "fast-simplex-noise": "^4.0.0",
    "form-data": "^4.0.5",
    "gradient-string": "^3.0.0",
    "inquirer": "^13.1.0",
    "jsonrepair": "^3.13.1",
    "langchain": "^1.2.3",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "openai": "^6.15.0",
    "ora": "^9.0.0",
    "p-limit": "3",
    "pg": "8.8.0",
    "pngjs": "^7.0.0",
    "prettyjson": "^1.2.5",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "seedrandom": "^3.0.5",
    "short-unique-id": "^5.3.2",
    "socket.io": "^4.8.1",
    "styled-components": "^6.0.0",
    "zod": "^4.3.5"
