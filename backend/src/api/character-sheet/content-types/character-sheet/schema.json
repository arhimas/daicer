{
  "kind": "collectionType",
  "collectionName": "character_sheets",
  "info": {
    "singularName": "character-sheet",
    "pluralName": "character-sheets",
    "displayName": "Character Sheet",
    "description": "Instance of a character in a game room"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "type": {
      "type": "enumeration",
      "enum": ["player", "monster", "npc"],
      "default": "player"
    },
    "monster": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::monster.monster"
    },
    "character": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::character.character"
    },
    "room": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::room.room",
      "inversedBy": "character_sheets"
    },
    "currentHp": {
      "type": "integer"
    },
    "maxHp": {
      "type": "integer"
    },
    "speed": {
      "type": "json"
    },
    "level": {
      "type": "integer",
      "default": 1
    },
    "experience": {
      "type": "integer",
      "default": 0
    },
    "stats": {
      "type": "component",
      "repeatable": false,
      "component": "game.stats"
    },
    "race": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::race.race"
    },
    "class": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::class.class"
    },
    "appearance": {
      "type": "json"
    },
    "backstory": {
      "type": "text"
    },
    "inventory": {
      "type": "component",
      "repeatable": true,
      "component": "game.inventory-item"
    },
    "position": {
      "type": "component",
      "repeatable": false,
      "component": "game.position"
    }
  }
}
