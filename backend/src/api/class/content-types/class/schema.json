    "name": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "description": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "hit_die": {
      "type": "string"
    },
    "subclasses": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::subclass.subclass",
      "mappedBy": "class"
    },
    "proficiencies": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::proficiency.proficiency",
      "inversedBy": "classes"
    },
    "image": {
      "type": "media",
