{
  "kind": "collectionType",
  "collectionName": "magic_items",
  "info": {
    "singularName": "magic-item",
    "pluralName": "magic-items",
    "displayName": "Magic Item",
    "description": "Magical items and artifacts (Structured)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "name": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "description": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "rarity": {
      "type": "enumeration",
      "enum": ["Common", "Uncommon", "Rare", "Very Rare", "Legendary", "Artifact", "Varies"]
    },
    "equipment_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::equipment-category.equipment-category"
    },
    "base_item": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::equipment.equipment",
      "description": "If this is a variant of a standard item (e.g. +1 Sword)"
    },
    "is_variant": {
      "type": "boolean",
      "default": false
    },
    "attunement_required": {
      "type": "boolean",
      "default": false
    },
    "attunement_condition": {
      "type": "string",
      "description": "e.g. 'by a paladin'"
    },
    "has_charges": {
      "type": "boolean",
      "default": false
    },
    "max_charges": {
      "type": "integer"
    },
    "recharge_trigger": {
      "type": "enumeration",
      "enum": ["Dawn", "Dusk", "Short Rest", "Long Rest", "Special"]
    },
    "recharge_formula": {
      "type": "string",
      "description": "e.g. '1d6+4'"
    },
    "active_abilities": {
      "type": "component",
      "repeatable": true,
      "component": "game.action",
      "description": "Spells or Actions granted by this item"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "image_url": {
      "type": "string"
    },
    "embedding": {
      "type": "json",
      "private": true
    },
    "embeddingMetadata": {
      "type": "json",
      "private": true
    }
  }
}
