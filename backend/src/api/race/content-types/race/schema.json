{
  "kind": "collectionType",
  "collectionName": "races",
  "info": {
    "singularName": "race",
    "pluralName": "races",
    "displayName": "Race",
    "description": "D&D 5e Races"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "name": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "description": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "speed": {
      "type": "json"
    },
    "size": {
      "type": "enumeration",
      "enum": ["Tiny", "Small", "Medium", "Large"]
    },
    "traits": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::trait.trait",
      "mappedBy": "races"
    },
    "proficiencies": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::proficiency.proficiency",
      "inversedBy": "races"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    }
  }
}
