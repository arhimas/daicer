{
  "kind": "collectionType",
  "collectionName": "rooms",
  "info": {
    "singularName": "room",
    "pluralName": "rooms",
    "displayName": "Room",
    "description": "Game room state"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "roomId": {
      "type": "uid",
      "unique": true
    },
    "owner": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "rooms"
    },
    "phase": {
      "type": "enumeration",
      "enum": [
        "lobby",
        "character_creation",
        "world_generation",
        "gameplay",
        "combat",
        "ending"
      ],
      "default": "lobby"
    },
    "worldDescription": {
      "type": "richtext"
    },
    "players": {
      "type": "component",
      "repeatable": true,
      "component": "game.player"
    },
    "history": {
      "type": "json"
    },
    "turnData": {
      "type": "json"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "code": {
      "type": "string",
      "unique": true
    },
    "settings": {
      "type": "json"
    },
    "character_sheets": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::character-sheet.character-sheet",
      "mappedBy": "room"
    },
    "turns": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::turn.turn",
      "mappedBy": "room"
    },
    "messages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::message.message",
      "mappedBy": "room"
    },
    "events": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::game-event.game-event",
      "mappedBy": "room"
    },
    "worldSize": {
      "type": "enumeration",
      "enum": [
        "intimate",
        "small",
        "medium",
        "large",
        "vast",
        "epic"
      ],
      "default": "small"
    },
    "adventureLength": {
      "type": "enumeration",
      "enum": [
        "flash",
        "short",
        "medium",
        "long",
        "epic",
        "legendary"
      ],
      "default": "short"
    },
    "difficulty": {
      "type": "enumeration",
      "enum": [
        "storyteller",
        "easy",
        "medium",
        "challenging",
        "gritty",
        "deadly"
      ],
      "default": "easy"
    },
    "startingLevel": {
      "type": "integer",
      "default": 1
    },
    "playerCount": {
      "type": "integer",
      "default": 4
    },
    "theme": {
      "type": "string"
    },
    "setting": {
      "type": "string"
    },
    "tone": {
      "type": "string"
    },
    "dmStyle": {
      "type": "component",
      "repeatable": false,
      "component": "game.dm-style"
    }
  }
}