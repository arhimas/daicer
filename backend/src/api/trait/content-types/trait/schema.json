{
  "kind": "collectionType",
  "collectionName": "traits",
  "info": {
    "singularName": "trait",
    "pluralName": "traits",
    "displayName": "Trait",
    "description": "D&D 5e Racial Traits"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "name": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true
    },
    "description": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "races": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::race.race",
      "inversedBy": "traits"
    },
    "proficiencies": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::proficiency.proficiency",
      "inversedBy": "traits"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    }
  }
}
