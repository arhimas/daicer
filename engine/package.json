{
    "name": "@daicer/engine",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
        "lint": "eslint . --ext .ts",
        "typecheck": "tsc --noEmit",
        "test": "vitest"
    },
    "dependencies": {
        "zod": "^3.22.4",
        "fast-simplex-noise": "^4.0.0",
        "three": "^0.160.0",
        "@faker-js/faker": "^8.4.1"
    },
    "devDependencies": {
        "tsup": "^8.0.2",
        "typescript": "^5.3.3",
        "vitest": "^1.3.1",
        "@types/three": "^0.160.0",
        "@types/node": "^20.11.24"
    }
}