{
  "name": "@daicer/backend",
  "version": "0.1.0",
  "private": true,
  "description": "A Strapi application",
  "scripts": {
    "dev": "mkdir -p logs && STRAPI_LOG_LEVEL=warn NODE_OPTIONS='--max-old-space-size=8192' strapi develop 2>&1 | tee logs/backend.log",
    "start": "strapi start",
    "build": "NODE_OPTIONS='--max-old-space-size=8192' strapi build",
    "strapi": "strapi",
    "deploy": "strapi deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:cli": "vitest src/cli/__tests__/cli-e2e.test.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "codegen": "NODE_OPTIONS='--max-old-space-size=8192' strapi ts:generate-types",
    "typecheck": "tsc --noEmit",
    "seed": "ts-node src/scripts/seed.ts",
    "reembed": "ts-node src/scripts/ingest-game-entities.ts",
    "feed:manuals": "ts-node src/scripts/ingest-manuals.ts",
    "feed:code": "ts-node src/scripts/ingest-codebase.ts",
    "feed:schemas": "ts-node src/scripts/ingest-schemas.ts",
    "feed:all": "yarn feed:manuals && yarn feed:code && yarn feed:schemas && yarn reembed",
    "sendcode": "ts-node src/scripts/send-code.ts",
    "wipe-knowledge": "ts-node src/scripts/wipe-embeddings.ts",
    "seed:test": "node scripts/seed-test-db.js",
    "db:dump": "node scripts/dump-db.js",
    "cli": "ts-node -T src/cli/index.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@bull-board/api": "^6.16.2",
    "@bull-board/koa": "^6.16.2",
    "@bull-board/ui": "^6.16.2",
    "@google/genai": "^1.34.0",
    "@huggingface/transformers": "^3.8.1",
    "@langchain/core": "^1.1.10",
    "@langchain/google-genai": "^2.1.3",
    "@langchain/langgraph": "^1.0.7",
    "@langchain/openai": "^1.2.1",
    "@langchain/textsplitters": "^1.0.1",
    "@radix-ui/react-use-effect-event": "^0.0.2",
    "@strapi-community/plugin-redis": "^2.0.0",
    "@strapi-community/strapi-provider-upload-google-cloud-storage": "^5.0.5",
    "@strapi/plugin-cloud": "5.32.0",
    "@strapi/plugin-graphql": "5.32.0",
    "@strapi/plugin-users-permissions": "5.32.0",
    "@strapi/strapi": "5.32.0",
    "@types/cli-progress": "^3.11.6",
    "@types/pg": "^8.16.0",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.13.2",
    "boxen": "^8.0.1",
