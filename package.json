{
  "name": "daicer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "backend",
    "frontend",
    "shared",
    "engine"
  ],
  "scripts": {
    "dev": "concurrently -n \"backend,frontend\" -c \"#4285F4,#0F9D58\" \"yarn workspace @daicer/backend dev\" \"yarn workspace @daicer/frontend dev\"",
    "build": "yarn workspaces run build",
    "start": "concurrently \"yarn workspace @daicer/backend start\" \"yarn workspace @daicer/frontend start\"",
    "lint": "yarn workspaces run lint",
    "typecheck": "yarn workspaces run typecheck",
    "test": "yarn workspaces run test",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "kill": "lsof -ti:3000,1337 | xargs kill -9 || true",
    "prepare": "husky"
  },
  "dependencies": {
    "@uidotdev/usehooks": "^2.4.1"
  },
  "devDependencies": {
    "@google/generative-ai": "^0.21.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "tsx": "^4.20.6"
  },
  "resolutions": {
    "camera-controls": "2.9.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
