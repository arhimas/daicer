    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "fast-simplex-noise": "^4.0.0",
    "form-data": "^4.0.5",
    "glob": "^13.0.0",
    "gradient-string": "^3.0.0",
    "inquirer": "^13.1.0",
    "jsonrepair": "^3.13.1",
    "langchain": "^1.2.3",
    "lodash": "^4.17.21",
    "moment": "^2.30.1",
    "openai": "^6.15.0",
    "ora": "^9.0.0",
    "p-limit": "3",
    "pg": "^8.17.1",
