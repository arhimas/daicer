              "raw": "{\n  \"name\": \"Elara\",\n  \"hp\": 40,\n  \"maxHp\": 40,\n  \"armorClass\": 16,\n  \"position\": {\n    \"x\": 5,\n    \"y\": 5\n  },\n  \"allegiance\": \"player\",\n  \"attributes\": {\n    \"strength\": 16,\n    \"dexterity\": 14,\n    \"constitution\": 13,\n    \"intelligence\": 10,\n    \"wisdom\": 12,\n    \"charisma\": 8\n  },\n  \"proficiencyBonus\": 2,\n  \"speed\": 30,\n  \"reach\": 5\n}"
            },
            "url": {
