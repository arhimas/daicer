{
  "info": {
    "_postman_id": "daicer-backend-api",
    "name": "DAICE Backend API",
    "description": "Complete API collection for the DAICE (D&D AI Collaborative Experience) backend. Includes all REST endpoints for rooms, game logic, assets, spells, characters, game data, and tactical combat.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{FIREBASE_ID_TOKEN}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:3001",
      "type": "string"
    },
    {
      "key": "FIREBASE_ID_TOKEN",
      "value": "",
      "type": "string"
    },
    {
      "key": "ROOM_ID",
      "value": "",
      "type": "string"
    },
    {
      "key": "PLAYER_ID",
      "value": "",
      "type": "string"
    },
    {
      "key": "ENCOUNTER_ID",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health & Diagnostics",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/health",
              "host": ["{{BASE_URL}}"],
              "path": ["health"]
            },
            "description": "Liveness probe for the backend service. Returns status and timestamp."
          },
          "response": []
        }
      ],
      "description": "Health check and diagnostics endpoints"
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/users/me",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "users", "me"]
            },
            "description": "Get or create current user profile based on Firebase authentication token. Creates user on first login."
          },
          "response": []
        }
      ],
      "description": "User profile endpoints"
    },
    {
      "name": "Rooms",
      "item": [
        {
          "name": "Create Room",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.success && jsonData.data && jsonData.data.id) {",
                  "        pm.collectionVariables.set('ROOM_ID', jsonData.data.id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/rooms",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "rooms"]
            },
            "description": "Create a new multiplayer room. Room owner is automatically set to authenticated user."
          },
          "response": []
        },
        {
          "name": "List My Rooms",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/rooms",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "rooms"]
            },
            "description": "List all rooms the current user belongs to (as owner or player)"
          },
          "response": []
        },
        {
          "name": "Join Room by Code",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/rooms/:code/join",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "rooms", ":code", "join"],
              "variable": [
                {
                  "key": "code",
                  "value": "ABC123",
                  "description": "6-character room code (uppercase)"
                }
              ]
            },
            "description": "Join a room using its short code"
          },
          "response": []
        },
        {
          "name": "Get Room State",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/rooms/:roomId",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "rooms", ":roomId"],
              "variable": [
                {
                  "key": "roomId",
                  "value": "{{ROOM_ID}}"
                }
              ]
            },
            "description": "Get room state including players and settings"
          },
          "response": []
        },
        {
          "name": "Update Room Settings",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"theme\": \"High Fantasy\",\n  \"setting\": \"Medieval Kingdom\",\n  \"tone\": \"Heroic\",\n  \"playerCount\": 4,\n  \"adventureLength\": \"medium\",\n  \"difficulty\": \"medium\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/rooms/:roomId/settings",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "rooms", ":roomId", "settings"],
              "variable": [
                {
                  "key": "roomId",
                  "value": "{{ROOM_ID}}"
                }
              ]
            },
            "description": "Update room settings. Only room owner can update."
          },
          "response": []
        },
        {
          "name": "Delete Room",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/rooms/:roomId",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "rooms", ":roomId"],
              "variable": [
                {
                  "key": "roomId",
                  "value": "{{ROOM_ID}}"
                }
              ]
            },
            "description": "Soft-delete a room. Only room owner can delete."
          },
          "response": []
        },
        {
          "name": "Leave Room",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/rooms/:roomId/membership",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "rooms", ":roomId", "membership"],
              "variable": [
                {
                  "key": "roomId",
                  "value": "{{ROOM_ID}}"
                }
              ]
            },
            "description": "Leave a room as a player member"
          },
          "response": []
        }
      ],
      "description": "Room lifecycle management endpoints"
    },
    {
      "name": "Game",
      "item": [
        {
          "name": "Generate World",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/game/:roomId/world",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "game", ":roomId", "world"],
              "variable": [
                {
                  "key": "roomId",
                  "value": "{{ROOM_ID}}"
                }
              ]
            },
            "description": "Generate world description and narrative seed based on room settings. Only room owner can generate. Uses language from room settings."
          },
          "response": []
        },
        {
          "name": "Add Character",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.success && jsonData.data && jsonData.data.id) {",
                  "        pm.collectionVariables.set('PLAYER_ID', jsonData.data.id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Elara the Brave\",\n  \"race\": \"Elf\",\n  \"characterClass\": \"Fighter\",\n  \"alignment\": \"Lawful Good\",\n  \"background\": \"Soldier\",\n  \"attributes\": {\n    \"Strength\": 16,\n    \"Dexterity\": 14,\n    \"Constitution\": 13,\n    \"Intelligence\": 10,\n    \"Wisdom\": 12,\n    \"Charisma\": 8\n  },\n  \"armorClass\": 16\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/game/:roomId/character",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "game", ":roomId", "character"],
              "variable": [
                {
                  "key": "roomId",
                  "value": "{{ROOM_ID}}"
                }
              ]
            },
            "description": "Submit a character to the room during character creation phase"
          },
          "response": []
        },
        {
          "name": "Start Adventure",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/game/:roomId/start",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "game", ":roomId", "start"],
              "variable": [
                {
                  "key": "roomId",
                  "value": "{{ROOM_ID}}"
                }
              ]
            },
            "description": "Generate personalized character openings and start the game. Only room owner can start. Uses language from room settings."
          },
          "response": []
        },
        {
          "name": "Process Turn",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/api/game/:roomId/turn",
              "host": ["{{BASE_URL}}"],
              "path": ["api", "game", ":roomId", "turn"],
              "variable": [
                {
                  "key": "roomId",
                  "value": "{{ROOM_ID}}"
                }
              ]
            },
            "description": "Execute game turn - processes all player actions and generates DM response using LangGraph"
          },
          "response": []
        }
      ],
      "description": "Game lifecycle and narrative generation endpoints"
    },
