{
  "uid": "api::construction.construction",
  "kind": "collectionType",
  "collectionName": "constructions",
  "info": {
    "singularName": "construction",
    "pluralName": "constructions",
    "displayName": "Construction",
    "description": "A saved voxel structure (village, castle, etc.)"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "village",
        "castle",
        "tower",
        "dungeon",
        "house",
        "shop",
        "temple",
        "misc"
      ],
      "default": "misc"
    },
    "width": {
      "type": "integer",
      "default": 16
    },
    "depth": {
      "type": "integer",
      "default": 16
    },
    "height": {
      "type": "integer",
      "default": 16
    },
    "voxels": {
      "type": "customField",
      "customField": "plugin::map-explorer.construction-grid",
      "required": true
    },
    "previewImage": {
      "type": "json",
      "description": "Base64 or similar preview data"
    }
  }
}