  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "instruction": {
      "type": "text",
      "required": true,
      "description": "Instructions for the LLM on how to generate this size"
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}