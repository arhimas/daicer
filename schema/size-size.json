{
  "uid": "api::size.size",
  "kind": "collectionType",
  "collectionName": "sizes",
  "info": {
    "singularName": "size",
    "pluralName": "sizes",
    "displayName": "Size",
    "description": "Entity size definitions and generation rules"
  },
  "options": {
