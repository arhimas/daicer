{
  "name": "@daicer/shared",
  "version": "1.0.0",
  "description": "Shared types, schemas, and test fixtures for Daicer",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./character": "./src/character/index.ts",
    "./character/types": "./src/character/types.ts",
    "./room": "./src/room/index.ts",
    "./room/types": "./src/room/types.ts",
    "./player": "./src/player/index.ts",
    "./player/types": "./src/player/types.ts",
    "./user": "./src/user/index.ts",
    "./user/types": "./src/user/types.ts",
    "./world": "./src/world/index.ts",
    "./world/history-schema": "./src/world/history-schema.ts",
    "./world/structure-schema": "./src/world/structure-schema.ts",
    "./world/road-schema": "./src/world/road-schema.ts",
    "./world/condition-schema": "./src/world/condition-schema.ts",
    "./graph-states": "./src/graph-states/index.ts",
    "./graph-states/dm-story": "./src/graph-states/dm-story-state.ts",
    "./graph-states/world-config": "./src/graph-states/world-config-state.ts",
    "./graph-states/character": "./src/graph-states/character-state.ts",
    "./graph-states/mergers": "./src/graph-states/mergers.ts",
    "./world-gen": "./src/world-gen/index.ts",
    "./world-gen/noise": "./src/world-gen/noise/index.ts",
    "./world-gen/cellular-automata": "./src/world-gen/cellular-automata/index.ts",
    "./world-gen/bsp": "./src/world-gen/bsp/index.ts",
    "./world-gen/voronoi": "./src/world-gen/voronoi/index.ts",
    "./world-gen/wfc": "./src/world-gen/wfc/index.ts",
    "./world-gen/structures": "./src/world-gen/structures/index.ts",
    "./world-gen/utils": "./src/world-gen/utils/index.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "test": "node --experimental-vm-modules ../node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules ../node_modules/jest/bin/jest.js --coverage",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "@faker-js/faker": "^10.1.0",
    "fast-simplex-noise": "^4.0.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.8.3"
  }
}
