{
  "kind": "collectionType",
  "collectionName": "compilation_reports",
  "info": {
    "singularName": "compilation-report",
    "pluralName": "compilation-reports",
    "displayName": "Compilation Report",
    "description": "Dead Letter Queue for Entity Compilation Failures"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "phase": {
      "type": "enumeration",
      "enum": [
        "Atom",
        "Molecule",
        "Compound",
        "Blueprint"
      ],
      "required": true,
      "deprecated": false
    },
    "entityType": {
      "type": "string",
      "required": true,
      "description": "The UID of the entity type (e.g. api::spell.spell)"
    },
    "entityId": {
      "type": "string",
      "required": true,
      "description": "The Document ID or Slug of the failed entity"
    },
    "entityName": {
      "type": "string",
      "description": "Readable name for quick ID"
    },
    "severity": {
      "type": "enumeration",
      "enum": [
        "Fatal",
        "Warning"
      ],
      "default": "Fatal"
    },
    "error": {
      "type": "text",
      "required": true
    },
    "logs": {
      "type": "json"
    },
    "resolved": {
      "type": "boolean",
      "default": false
    }
  }
}
