{
  "collectionName": "components_game_inventory_items",
  "info": {
    "displayName": "Inventory Item",
    "description": "An item in an inventory or slot"
  },
  "options": {},
  "attributes": {
    "item": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::item.item"
    },
    "quantity": {
      "type": "integer",
      "default": 1,
      "min": 1
    },
    "slot": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::anchor.anchor"
    },
    "isEquipped": {
      "type": "boolean",
      "default": false
    }
  }
}
